               <l>UTSTÄLLDA MÅLNINGAR</l>
               <l rend="smallCaps">AF</l>
               <l>ÄLDRE SVENSKA MÄSTARE.</l>
               
               <metamark function="divider" ana="#line"/>      <!-- Här har jag testat att markera linjerna med <metamark> -->
               
               <l>ANDRA AFDELNINGEN.</l>
               </div>
               <div>
               <l ana="#sansSerif">GUSTAVIANSKA TIDEHVARFVETS MÄSTARE</l>           
               <l ana="#oldStyleSerif">(<date when="1770">1770</date> &#8212; <date when="1809">1809</date>).</l>
               <l ana="#oldStyleSerif">FÖRSTA SERIEN.</l>
               </div>
               <metamark function="divider" ana="#line"/>
            </div>
         </div>
     
   
            <div type="imprint" rend="center" ana="#oldStyleSerif">
               <l><placeName>STOCKHOLM</placeName>, <date when="1870">1870.</date></l>
               <l rend="smallCaps expandedTracking">P.A. NORSTEDT &amp; SÖNER</l>
               <l rend="smallCaps">KONGL. BOKTRYCKARE.</l>
            </div>
       
         
         <div type="page" facs="#back1870" rend="left" ana="#oldStyleSerif">
            
               <metamark function="pagenumber" place="top-left"><num>12</num></metamark>
            
            <l><name><surname rend="bold">Åkerström</surname>, <forename rend="italics">Jonas</forename></name>, f. 1759, Dekorationsmålare, reste </l>
            <l>ut till Italien, &#10013; i Rom 1795. Elev af Desprez</l> 
            <l>och Masreliez.</l>
            <l>N:o 59. Meleager, vägrande att gå till striden, be-</l> 
            <l>vekes af sin makas tårar; komposition</l> 
            <l>med många figurer. Receptionsstycke</l> 
